{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policygpt.com/contracts/quote-job.schema.json",
  "title": "PolicyGPT Quote Job (Coordinator -> Rater)",
  "description": "Appendix A of POLICYGPT_ARCHITECTURE_PLAN.md. Single source of truth; do NOT hand-copy into repos -- vendor this file. Changes are spec changes (architecture plan section 23.1).",
  "type": "object",
  "required": [
    "schema_version",
    "quote_session_id",
    "job_id",
    "attempt",
    "fulfillment_mode",
    "line_of_business",
    "profession",
    "business_type",
    "customer"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "major.minor. Consumers reject an unknown MAJOR version."
    },
    "quote_session_id": { "type": "string" },
    "job_id": { "type": "string" },
    "attempt": { "type": "integer", "minimum": 1 },
    "fulfillment_mode": { "enum": ["automated", "manual"] },
    "quote_type": { "type": "string" },
    "line_of_business": { "type": "string" },
    "profession": { "type": "string" },
    "insurance_type": { "type": "string" },
    "business_type": {
      "type": "string",
      "description": "MUST be forwarded by the plugin. Required here to enforce the known drop-bug fix (architecture plan section 2.1)."
    },
    "naics_code": { "type": "string" },
    "customer": {
      "type": "object",
      "required": ["name", "email"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" }
      }
    },
    "business": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "legal_name": { "type": "string" },
        "dba": { "type": "string" },
        "entity_type": { "type": "string" },
        "website": { "type": "string" },
        "start_year": { "type": "string" },
        "primary_address": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "street_1": { "type": "string" },
            "street_2": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zip": { "type": "string" }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "effective_date": { "type": "string" },
        "limits": { "type": "string" },
        "deductible": { "type": "string" }
      }
    },
    "operations": { "type": "object" },
    "revenue": { "type": "object" },
    "prior_eo": { "type": "object" },
    "claims": { "type": "object" },
    "history": { "type": "object" },
    "underwriting_answers": { "type": "object" },
    "carrier_specific_answers": { "type": "object" },
    "documents": { "type": "array" },
    "carrier_strategy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "preferred_carriers": { "type": "array", "items": { "type": "string" } },
        "excluded_carriers": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
