    "agency_rules": {
      "freshness_mode": "time_decay",
      "freshness_horizon_months": 12
    }
  },
  "_bucket_freshness_defaults_note": "Per-family freshness seed defaults the coordinator applies when seeding buckets from this taxonomy. Families not listed default to time_decay / 24 months. evergreen = age irrelevant (excluded from scoring, never expires).",
